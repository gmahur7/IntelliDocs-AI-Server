PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/app_db?schema=public"
NODE_ENV=development
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=1d
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
# Use the exact S3 URL from Bucket → Endpoint in Backblaze (region includes a number, e.g. us-east-005).
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
# Optional: same as the segment between s3. and .backblazeb2.com (e.g. us-east-005 — not "us-east" alone)
# B2_REGION=us-east-005
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_INGEST_QUEUE=doc.ingest.parse
RABBITMQ_INGEST_DLQ=doc.ingest.deadletter
RABBITMQ_PREFETCH_COUNT=5
RABBITMQ_MAX_RETRIES=3
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_DEFAULT_TOP_K=5
